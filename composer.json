{
  "name" : "dave-liddament/sarb",
  "type": "project",
  "description": "Provides tools for baselining static analysis results and comparing against that baseline",
  "keywords" : ["php", "baseline", "static analysis"],
  "license" : "MIT",
  "authors" : [
    {
      "name" : "Dave Liddament",
      "email" : "daveliddament@gmail.com"
    }
  ],
  "config": {
    "sort-packages": true
  },
  "require": {
    "php": ">=8.2 <8.6",
    "symfony/config": "^6.4 || ^7",
    "symfony/console": "^6.4 || ^7",
    "symfony/dependency-injection": "^6.4 || ^7",
    "symfony/process": "^6.4 || ^7",
    "symfony/yaml": "^6.4 || ^7",
    "webmozart/assert": "^1.11"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.91",
    "kubawerlos/php-cs-fixer-custom-fixers": "^3.22",
    "php-parallel-lint/php-parallel-lint": "^1.4.0",
    "php-parallel-lint/php-var-dump-check": "^v0.5",
    "phpat/phpat": "^0.12",
    "phpstan/phpstan": "^2",
    "phpstan/phpstan-phpunit": "^2",
    "phpstan/phpstan-strict-rules": "^2",
    "phpstan/phpstan-webmozart-assert": "^2",
    "phpunit/phpunit": "^11",
    "rregeer/phpunit-coverage-check": "^0.3.1",
    "symfony/filesystem": "^6.4 || ^7"
  },
  "conflict": {
    "nikic/php-parser": "<4.18"
  },
  "bin" : ["sarb"],
  "autoload": {
    "psr-4": {
      "DaveLiddament\\StaticAnalysisResultsBaseliner\\" : "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DaveLiddament\\StaticAnalysisResultsBaseliner\\Tests\\" : "tests/",
      "Tools\\" : "tools/"
    }
  },
  "scripts": {
    "ci" : [
      "@composer-validate",
      "@lint",
      "@var-dump-checker",
      "@cs",
      "@test-with-coverage-check",
      "@phpstan"
    ],
    "composer-validate" : "@composer validate --no-check-all --strict",
    "lint" : "parallel-lint --exclude tests/scratchpad src tests",
    "var-dump-checker" : "var-dump-check --ladybug --no-colors src",
    "cs" : "php-cs-fixer fix -v --dry-run",
    "cs-fix" : "php-cs-fixer fix -v",
    "phpstan" : "phpstan -n --no-progress  analyse",
    "test" : [
      "@putenv XDEBUG_MODE=coverage",
      "phpunit --coverage-clover=reports/clover.xml"
    ],
    "test-with-coverage-check" : [
      "@putenv XDEBUG_MODE=coverage",
      "phpunit --coverage-clover=reports/clover.xml",
      "coverage-check reports/clover.xml 100"
    ]

  }
}
